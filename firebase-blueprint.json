{
  "entities": {
    "Assessment": {
      "title": "Assessment",
      "description": "Primary Care Quality Standards Assessment for year 2026",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique ID of the assessment, typically the sanitized email"
        },
        "unitEmail": {
          "type": "string",
          "description": "Email address of the primary care unit"
        },
        "unitName": {
          "type": "string",
          "description": "Name of the primary care service center/unit"
        },
        "district": {
          "type": "string",
          "description": "District (Amphoe) of the unit"
        },
        "province": {
          "type": "string",
          "description": "Province (Changwat) of the unit"
        },
        "scores": {
          "type": "object",
          "description": "Map of item identifiers to scored values"
        },
        "notes": {
          "type": "object",
          "description": "Map of item identifiers to notes or evidence notes"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last update"
        }
      },
      "required": [
        "id",
        "unitEmail",
        "unitName"
      ]
    },
    "EvidenceFile": {
      "title": "EvidenceFile",
      "description": "Document evidence attached to a specific assessment item/standard",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique file ID"
        },
        "itemId": {
          "type": "string",
          "description": "Standard identifier (e.g. s1_1.1, s5_2.1)"
        },
        "name": {
          "type": "string",
          "description": "Original file name"
        },
        "type": {
          "type": "string",
          "description": "MIME type (e.g., application/pdf, image/png)"
        },
        "size": {
          "type": "number",
          "description": "Size in bytes"
        },
        "data": {
          "type": "string",
          "description": "Base64 data representation"
        },
        "uploadedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Date of upload"
        }
      },
      "required": [
        "id",
        "itemId",
        "name",
        "type",
        "data"
      ]
    },
    "ActivityLog": {
      "title": "ActivityLog",
      "description": "Trail of changes and modifications made by uploaders in the system",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique log identifier"
        },
        "userEmail": {
          "type": "string",
          "description": "Email address of the user who performed the action"
        },
        "unitName": {
          "type": "string",
          "description": "Name of the service unit where the edit happened"
        },
        "action": {
          "type": "string",
          "description": "Category of the action: e.g. edit_evaluation, upload_file, delete_file"
        },
        "itemId": {
          "type": "string",
          "description": "The item / standard identifier affected"
        },
        "itemCode": {
          "type": "string",
          "description": "Code of the item"
        },
        "itemName": {
          "type": "string",
          "description": "Name of the item"
        },
        "details": {
          "type": "string",
          "description": "Detailed text describing the modification"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO timestamp of when the action occurred"
        }
      },
      "required": [
        "id",
        "userEmail",
        "action",
        "details",
        "timestamp"
      ]
    }
  },
  "firestore": {
    "/assessments/{assessmentId}": {
      "schema": "Assessment",
      "description": "Firestore collection storing unit quality assessments"
    },
    "/assessments/{assessmentId}/files/{fileId}": {
      "schema": "EvidenceFile",
      "description": "Subcollection storing attached PDF, Word, and Image files for the assessment"
    },
    "/activity_logs/{logId}": {
      "schema": "ActivityLog",
      "description": "Collection tracking editing history and audit logs"
    }
  }
}
